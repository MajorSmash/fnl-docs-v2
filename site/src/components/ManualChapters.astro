---
import { getEntry } from 'astro:content';
import { sitePath } from '../lib/site-path.mjs';
import { manualChaptersFromHeadings } from '../lib/manual-navigation.mjs';

const manual = await getEntry('docs', 'manual/ninjalive2-manual');
const headings = (manual?.rendered?.metadata?.headings ?? []) as Array<{
  depth: number;
  slug: string;
  text: string;
}>;
const chapters = manualChaptersFromHeadings(headings);
---

{
  chapters.length ? (
    <ol class="chapter-grid not-content">
      {chapters.map((chapter) => (
        <li>
          <a href={`${sitePath('manual/ninjalive2-manual/') }#${chapter.slug}`}>
            <span>{chapter.number}</span>
            {chapter.title}
          </a>
        </li>
      ))}
    </ol>
  ) : (
    <p>The manual is available as one canonical document with an on-page table of contents.</p>
  )
}
