{
  "name": "fnl-docs-v2-site",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "astro dev",
    "check": "astro check",
    "test": "node --test tests/*.test.mjs",
    "build": "astro build",
    "check:links": "node scripts/check-internal-links.mjs",
